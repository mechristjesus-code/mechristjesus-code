DATABASE_URL=postgres://postgres:postgres@localhost:5432/vibe_next_template
LOG_DIR=./vibe-next-template

NOVA_BASE_URL=xxx
NOVA_TENANT_ID=tenant_xxx
NOVA_ACCESS_KEY=access_key_xxx

LLM_BASE_URL=example
LLM_API_KEY=xxx

# Reactus API
REACTUS_BASE_URL=https://dev-reactus-api.happyseeds.ai

# Happy Seeds
HAPPYSEEDS_PROJECT_ID=

# Umami Analytics
NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://your-umami-domain/script.js"
NEXT_PUBLIC_UMAMI_WEBSITE_ID="your-website-id"

# ─── Creator DNA OS ───────────────────────────────────────────────────────────
APP_NAME=Creator DNA OS
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# JWT — MUST change SECRET_KEY in production
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL
POSTGRES_USER=cdna_user
POSTGRES_PASSWORD=cdna_secret
POSTGRES_DB=creator_dna
CDNA_DATABASE_URL=postgresql://cdna_user:cdna_secret@localhost:5432/creator_dna

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI — REQUIRED for AI features
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=10

# Media uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100
ALLOWED_MEDIA_TYPES=video/mp4,audio/mpeg,audio/wav

# YouTube Data API v3 (for search + transcript)
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# Google OAuth2 — for YouTube upload from Creator Studio
# Create at: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:13000/api/auth/google
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
NEXT_PUBLIC_APP_URL=http://localhost:13000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=Creator DNA OS

# Internal service URLs (used by API Gateway)
AUTH_SERVICE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8002
DNA_SERVICE_URL=http://localhost:8003
MEMORY_SERVICE_URL=http://localhost:8004
MEDIA_SERVICE_URL=http://localhost:8005
PROJECTS_SERVICE_URL=http://localhost:8006
